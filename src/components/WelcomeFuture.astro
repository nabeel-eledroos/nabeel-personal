---
import '../styles/fonts.css';
import '../styles/animations.css';
import GradientBackground from './GradientBackground.astro';
---

<div id="container">
	<GradientBackground />
	<main>
		<section id="nametag-section">
			<h1 id="nametag">
				NABEEL ELEDROOS
			</h1>
		</section>
		<section id="menu-section">
			<a href="/graphic-design/GraphicDesign" class="menu-item">
				Graphic Design
			</a>
			<a href="/photography/Photography" class="menu-item">
				Photography
			</a>
			<a href="/video/Video" class="menu-item">
				Video
			</a>
			<a href="/projects/Projects" class="menu-item">
				Projects
			</a>
			<a href="https://nabeel-eledroos.github.io/data/nabeel_resume.pdf" target="_blank" rel="noopener noreferrer" class="menu-item">
				Resume
			</a>
		</section>
	</main>
</div>

<style>
	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100%;
		position: relative;
		overflow: hidden;
	}

	main {
		height: 100%;
		display: block;
		justify-content: center;
		position: relative;
		z-index: 1;
	}

	#nametag-section {
		display: block;
		justify-content: center;
		width: 100%;
	}

	#nametag {
		color: rgba(0, 0, 0, 0.95);
		text-align: center;
		font-family: "Te-Quirtez", sans-serif;
		font-weight: 100;
		font-style: normal;
		font-size: 65px;
		font-optical-sizing: auto;
		transition: font-size 2s ease, text-shadow 1s ease;
		cursor: default;
		/* text-shadow: 
			0 2px 20px rgba(200, 150, 180, 0.5),
			0 4px 40px rgba(180, 140, 200, 0.3); */
		letter-spacing: 0.05em;
	}

	#nametag:hover {
		font-size: 80px;
		text-shadow: 
			0 2px 30px rgba(255, 255, 255, 0.6),
			/* 0 4px 60px rgba(200, 150, 180, 0.5); */
		animation: float 10s ease-in-out infinite;
	}

	#menu-section {
		justify-content: center;
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
	}

	.menu-item {
		color: rgba(60, 60, 60, 0.85);
		font-family: "Te-Quirtez", sans-serif;
		font-optical-sizing: auto;
		font-weight: 400;
		font-style: normal;
		text-align: center;
		font-size: 50px;
		cursor: pointer;
		transition: font-size 2s ease, text-shadow 0.5s ease, color 0.5s ease;
		display: inline-block;
		width: auto;
		padding: 2px;
		text-decoration: none;
		margin: 32px 0px;
		/* text-shadow: 
			0 2px 15px rgba(180, 140, 180, 0.4),
			0 4px 30px rgba(200, 160, 190, 0.2); */
	}

	.menu-item:hover {
		font-size: 70px;
		color: rgba(255, 255, 255, 1);
		text-shadow: 
			0 2px 25px rgba(255, 255, 255, 0.5),
			0 4px 50px rgba(200, 150, 180, 0.4);
		animation: float 10s ease-in-out infinite;
	}
	
	@media screen and (max-width: 768px) {
		#container {
			display: flex;
			flex-direction: column;
		}

		#nametag-section {
			display: block;
			padding-top: 10%;
		}

		h1 {
			line-height: 1.5;
		}
	}
</style>
