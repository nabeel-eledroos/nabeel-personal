---
import background from '../assets/images/background.svg';
import GridBackground from './GridBackground.astro';
import GradientBackground from './GradientBackground.astro';
import StyleSwitcher from './StyleSwitcher.astro';
import '../styles/fonts.css';
import '../styles/animations.css';
---

<div id="container">
	<div class="background-y2k-grid">
		<GridBackground />
		<img id="background" src={background.src} alt="" fetchpriority="high" />
	</div>
	<div class="background-ethereal">
		<GradientBackground />
	</div>
	<StyleSwitcher />
	<div class="inset-border"></div>
	<main>
		<section id="nametag-section">
			<h1 id="nametag">
				<span class="name-y2k-grid">NABEEL ELEDROOS</span>
				<span class="name-ethereal">Nabeel Eledroos</span>
			</h1>
		</section>
		<nav id="menu-section">
			<a href="/graphic-design/GraphicDesign" class="menu-item">
				Graphic Design
			</a>
			<a href="/photography/Photography" class="menu-item">
				Photography
			</a>
			<a href="/video/Video" class="menu-item">
				Video
			</a>
			<a href="/projects/Projects" class="menu-item">
				Projects
			</a>
			<a href="https://nabeel-eledroos.github.io/data/nabeel_resume.pdf" target="_blank" rel="noopener noreferrer" class="menu-item">
				Resume
			</a>
		</nav>
	</main>
</div>

<style>
	a {
		text-decoration: none;
	}

	#background {
		position: fixed;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		z-index: -1;
		filter: blur(100px);
	}

	#container {
		font-family: Inter, Roboto, 'Helvetica Neue', 'Arial Nova', 'Nimbus Sans', Arial, sans-serif;
		height: 100vh;
		width: 100vw;
		position: relative;
		overflow: hidden;
	}

	.inset-border {
		position: fixed;
		top: 20px;
		left: 20px;
		right: 20px;
		bottom: 20px;
		border: 1px solid rgba(255, 248, 240, 0.2);
		pointer-events: none;
		z-index: 50;
		opacity: 0;
		transition: opacity 0.5s ease;
	}

	main {
		height: 100%;
		width: 100%;
		display: flex;
		position: relative;
	}

	#nametag-section {
		position: fixed;
		bottom: 60px;
		left: 60px;
		display: inline-block;
	}

	#nametag {
		margin: 0;
		cursor: default;
		white-space: nowrap;
		position: relative;
		display: inline-block;
		padding-right: 20px;
		transition: font-size 2s ease;
	}

	.name-y2k-grid, .name-ethereal {
		display: inline-block;
		transition: opacity 0.5s ease, font-size 1.5s ease-in-out, color 1.5s ease-in-out, text-shadow 1.5s ease-in-out;
	}

	.name-y2k-grid {
		color: rgba(188, 82, 238, 0.8);
		font-family: "kabisat", sans-serif;
		font-weight: 400;
		font-style: normal;
		font-size: 55px;
		font-optical-sizing: auto;
		text-shadow: 0 0 0px rgba(188, 82, 238, 0);
	}

	#nametag:hover .name-y2k-grid {
		font-size: 60px;
		color: rgba(188, 82, 238, 1);
		text-shadow: 0 0 25px rgba(188, 82, 238, 0.7), 0 0 50px rgba(188, 82, 238, 0.5);
	}

	.name-ethereal {
		color: #fff8f0;
		font-family: "Bodoni Moda", serif;
		font-weight: 400;
		font-style: italic;
		font-size: 64px;
		position: absolute;
		bottom: 0;
		left: 0;
		text-shadow: 0 0 0px rgba(255, 248, 240, 0);
	}

	#nametag:hover .name-ethereal {
		font-size: 70px;
		text-shadow: 0 0 30px rgba(255, 248, 240, 0.6), 0 0 60px rgba(255, 200, 168, 0.4);
	}

	#menu-section {
		position: fixed;
		right: 60px;
		top: 50%;
		transform: translateY(-50%);
		display: flex;
		flex-direction: column;
		align-items: flex-end;
		gap: 16px;
	}

	.menu-item {
		font-optical-sizing: auto;
		font-weight: 900;
		font-style: normal;
		text-align: right;
		font-size: 42px;
		cursor: pointer;
		transition: font-size 0.5s ease, color 0.5s ease, font-family 0.3s ease;
		display: inline-block;
		padding: 4px 0;
	}

	.menu-item:hover {
		font-size: 52px;
	}

	/* Ethereal (default) */
	.background-y2k-grid { display: none; }
	.background-ethereal { display: block; }
	.name-y2k-grid { opacity: 0; }
	.name-ethereal { opacity: 1; }
	.inset-border { opacity: 1; }
	.menu-item {
		color: rgba(255, 248, 240, 0.85);
		font-family: "Cormorant", serif;
		font-style: italic;
		font-weight: 500;
	}
	.menu-item:hover {
		color: #fff8f0;
	}

	/* Y2K Grid */
	:global([data-theme="y2k-grid"]) .background-y2k-grid { display: block; }
	:global([data-theme="y2k-grid"]) .background-ethereal { display: none; }
	:global([data-theme="y2k-grid"]) .name-y2k-grid { opacity: 1; }
	:global([data-theme="y2k-grid"]) .name-ethereal { opacity: 0; }
	:global([data-theme="y2k-grid"]) .inset-border { opacity: 0; }
	:global([data-theme="y2k-grid"]) .menu-item {
		color: rgba(100, 98, 194, 0.6);
		font-family: "Crash", sans-serif;
		font-style: normal;
		font-weight: 900;
	}
	:global([data-theme="y2k-grid"]) .menu-item:hover {
		animation: glow-menu-item 1.5s ease-in-out forwards;
	}

	@media screen and (max-width: 768px) {
		#nametag-section {
			position: fixed;
			bottom: auto;
			top: 40px;
			left: 20px;
		}

		.name-styleA {
			font-size: 36px;
		}

		.name-styleB {
			font-size: 42px;
		}

		#menu-section {
			position: fixed;
			right: auto;
			left: 20px;
			top: 50%;
			transform: translateY(-50%);
			align-items: flex-start;
		}

		.menu-item {
			font-size: 32px;
		}

		.menu-item:hover {
			font-size: 38px;
		}

		.inset-border {
			top: 10px;
			left: 10px;
			right: 10px;
			bottom: 10px;
		}
	}
</style>
